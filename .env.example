# Pi Trader — Environment Variables
# Copy to .env and fill in your values

# ── Binance ────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Paper mode: true = simulate trades (no real money), false = live trading
PAPER_MODE=true

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── AMR5 Bridge (optional — Pi works standalone without this) ──────────────
AMR5_HOST=http://192.168.1.23
AMR5_OLLAMA_PORT=11435
AMR5_MODEL=qwen3:8b
AMR5_TIMEOUT=2.0

# ── Local LLM on Pi ────────────────────────────────────────────────────────
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=qwen3.5:0.8b
LOCAL_LLM_TIMEOUT=30.0

# ── Database ───────────────────────────────────────────────────────────────
# DB_PATH=/home/pi/pi_trader/pi_trader.db

# ── Trading Parameters ─────────────────────────────────────────────────────
MAX_POSITIONS=3
RISK_PER_TRADE=0.02       # 2% of pool per trade
SAFE_POOL_RATIO=0.70      # 70% safe, 30% aggressive
DAILY_LOSS_LIMIT=0.05     # pause if daily loss > 5%
MAX_HOLD_HOURS=4.0

# ── Signal Thresholds (autotuner adjusts these) ────────────────────────────
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
BB_SQUEEZE=0.03
VOL_RATIO=2.5
